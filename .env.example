# =====================================================================
# RA OpenVPN — Configuration Template
# Copy this to .env and fill in real values.
# =====================================================================

# ---- Compose project name ----
COMPOSE_PROJECT_NAME=ra-openvpn

# ---- Container names ----
RA_OPENVPN_CONTAINER_NAME=ra-openvpn
RA_OPENVPN_UI_CONTAINER_NAME=ra-openvpn-ui

# ---- Image versions (pin to specific tags for reproducibility) ----
RA_OPENVPN_IMAGE=d3vilh/openvpn-server:0.5.5
RA_OPENVPN_UI_IMAGE=d3vilh/openvpn-ui:0.9.5.6

# ---- Networking ----
RA_OPENVPN_HOST_PORT=1195
RA_OPENVPN_CONTAINER_PORT=1194
RA_OPENVPN_UI_CONTAINER_PORT=8080
RA_OPENVPN_PROTO=tcp

# Web UI binding — leave both for now, remove one later for security
RA_OPENVPN_UI_BIND_LOCAL=127.0.0.1
RA_OPENVPN_UI_BIND_LAN=192.168.7.20
RA_OPENVPN_UI_PORT=8045

# ---- Admin credentials ----
RA_OPENVPN_ADMIN_USERNAME=admin
RA_OPENVPN_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---- OpenVPN advertised subnets (for TRUST/GUEST/HOME env vars in image) ----
RA_TRUST_SUB=10.0.0.0/8
RA_GUEST_SUB=172.16.0.0/12
RA_HOME_SUB=192.168.0.0/16

# ---- VPN tunnel subnet (must match server.conf `server` directive) ----
# Must not collide with any physical LAN or another VPNs 10.7.0.0/24 or 10.8.0.0/24
RA_VPN_CLIENT_SUBNET=10.99.99.0/24

# ---- Host firewall settings ----
RA_LAN_INTERFACE=eno1
# Space-separated list of subnets allowed to reach the Web UI
RA_UI_ALLOWED_SUBNETS="192.168.5.0/24 192.168.6.0/24 192.168.7.0/24 10.99.99.0/24"

# ---- Docker internal bridge network ----
RA_DOCKER_NET_NAME=ra_openvpn_net
RA_DOCKER_NET_SUBNET=172.20.0.0/24

# ---- Restart policy ----
RA_RESTART_POLICY=unless-stopped
